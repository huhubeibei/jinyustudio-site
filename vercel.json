{
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/gallery/assets/(.*)",
      "dest": "/gallery/assets/$1"
    },
    {
      "src": "/gallery/(.*)",
      "dest": "/gallery/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
